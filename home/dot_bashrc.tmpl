# Source all shell modules
if [ -d ~/.shell ] && ls ~/.shell/*.sh 1>/dev/null 2>&1; then
  for file in ~/.shell/*.sh; do
    if [ -r "$file" ]; then
      source "$file"
    else
      echo "[shell] WARNING: Cannot read $file (check permissions)" >&2
    fi
  done
else
  echo "[shell] WARNING: ~/.shell/ directory missing or empty" >&2
fi
