# Path to oh-my-zsh installation
export ZSH="{{ .chezmoi.homeDir }}/.oh-my-zsh"

# Theme
ZSH_THEME="spaceship"

# Auto-correction
ENABLE_CORRECTION="true"

# Plugins
plugins=(
  git
  oath
  zsh-autosuggestions
  zsh-syntax-highlighting
  forgit
)

autoload -U compinit && compinit

source "$ZSH/oh-my-zsh.sh"

# Source all shell modules
if [ -d ~/.shell ] && ls ~/.shell/*.sh 1>/dev/null 2>&1; then
  for file in ~/.shell/*.sh; do
    if [ -r "$file" ]; then
      source "$file"
    else
      echo "[shell] WARNING: Cannot read $file (check permissions)" >&2
    fi
  done
else
  echo "[shell] WARNING: ~/.shell/ directory missing or empty" >&2
fi
