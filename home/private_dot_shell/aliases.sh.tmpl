#!/bin/sh
# General aliases and utility functions

# Terminal improvements
alias cp='cp -iv'
alias mv='mv -iv'
alias mkdir='mkdir -pv'
{{ if eq .chezmoi.os "darwin" -}}
alias ll='ls -FGlAhp'
{{ else -}}
alias ll='ls -FlAhp --color'
{{ end -}}
alias less='less -FSRXc'
alias cd..='cd ../'
alias ..='cd ../'
alias ...='cd ../../'
alias .3='cd ../../../'
alias .4='cd ../../../../'
alias .5='cd ../../../../../'
alias .6='cd ../../../../../../'
alias c='clear'
alias path='echo -e ${PATH//:/\\n}'
alias fix_stty='stty sane'
alias cic='set completion-ignore-case On'

cd() { builtin cd "$@"; ll; }
mcd() { mkdir -p "$1" && cd "$1"; }

# File management
zipf() { zip -r "$1".zip "$1"; }
alias numFiles='echo $(ls -1 | wc -l)'

extract() {
  if [ -f "$1" ]; then
    case "$1" in
      *.tar.bz2) tar xjf "$1" ;;
      *.tar.gz)  tar xzf "$1" ;;
      *.bz2)     bunzip2 "$1" ;;
      *.rar)     unrar e "$1" ;;
      *.gz)      gunzip "$1" ;;
      *.tar)     tar xf "$1" ;;
      *.tbz2)    tar xjf "$1" ;;
      *.tgz)     tar xzf "$1" ;;
      *.zip)     unzip "$1" ;;
      *.Z)       uncompress "$1" ;;
      *.7z)      7z x "$1" ;;
      *)         echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

pyclean() {
  find . | grep -E "(__pycache__|\.py[cod]$)" | xargs rm -rf
}

# Searching
alias qfind="find . -name "
ff() { find . -name "$@"; }
ffs() { find . -name "$@"'*'; }
ffe() { find . -name '*'"$@"; }

# Process management
findPid() { lsof -t -c "$@"; }
alias cpu_hogs='ps wwaxr -o pid,stat,%cpu,time,command | head -10'

# Tmux — deactivate conda before launching to avoid env pollution
alias tmux='command -v conda > /dev/null && conda deactivate; tmux'

# Full recursive directory listing
alias lr='ls -R | grep ":$" | sed -e '\''s/:$//'\'' -e '\''s/[^-][^\/]*\//--/g'\'' -e '\''s/^/   /'\'' -e '\''s/-/|/'\'' | less'

mans() {
  man "$1" | grep -iC2 --color=always "$2" | less
}
